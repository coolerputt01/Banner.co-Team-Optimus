# ─── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://your-api-identifier

# ─── App ──────────────────────────────────────────────────────────────────────
# Frontend URL — used for logout redirect and auth callback redirect
APP_BASE_URL=http://localhost:3000
SECRET_KEY=change_me_to_a_long_random_string

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bannerco

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Squadco ──────────────────────────────────────────────────────────────────
SQUAD_SECRET_KEY=sandbox_sk_your_key_here
SQUAD_SECRET_HASH=your_webhook_secret_hash
SQUAD_TEST_MODE=true
